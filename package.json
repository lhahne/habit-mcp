{
  "name": "habit-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Single-user habit tracker MCP server running on Cloudflare Workers + D1.",
  "type": "module",
  "main": "src/index.ts",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm build:ui && wrangler dev",
    "deploy": "pnpm build:ui && wrangler deploy",
    "build:ui": "node scripts/build-ui.mjs",
    "migrate:local": "wrangler d1 migrations apply DB --local",
    "migrate:remote": "wrangler d1 migrations apply DB --remote",
    "typecheck": "tsc --noEmit && tsc --noEmit -p src/ui/client/tsconfig.json",
    "test": "pnpm build:ui && vitest run",
    "test:watch": "pnpm build:ui && vitest",
    "test:e2e": "pnpm build:ui && node --experimental-strip-types e2e/prepare.ts && playwright test",
    "test:e2e:ui": "pnpm build:ui && node --experimental-strip-types e2e/prepare.ts && playwright test --ui"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.11.2",
    "jose": "^6.2.2",
    "vue": "^3.5.32",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.7",
    "@cloudflare/workers-types": "^4.20260418.0",
    "@playwright/test": "^1.59.1",
    "esbuild": "^0.27.7",
    "typescript": "^5.9.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.83.0"
  }
}
